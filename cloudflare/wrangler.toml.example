# Cloudflare cutover scaffold — NOT deployed in Phase 1.
# Copy to wrangler.toml and bind namespaces when Dispatch sets up the account.

name = "le-pro-api"
main = "worker.mjs"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

[vars]
STORAGE_BACKEND = "cloudflare"

[[kv_namespaces]]
binding = "LE_KV"
id = "<KV_NAMESPACE_ID>"

[[r2_buckets]]
binding = "LE_R2"
bucket_name = "le-pro-docs"

[triggers]
crons = ["0 6 * * *"]